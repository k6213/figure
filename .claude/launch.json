{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "HeroFig Backend (FastAPI)",
      "runtimeExecutable": "backend/venv/Scripts/python",
      "runtimeArgs": [
        "-c",
        "import os, sys; os.chdir('backend'); sys.path.insert(0, '.'); import uvicorn; uvicorn.run('app.main:app', reload=True, port=8000, host='127.0.0.1')"
      ],
      "port": 8000
    },
    {
      "name": "HeroFig Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true,
      "cwd": "frontend"
    },
    {
      "name": "FigureRoom Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "C:\\Users\\zxdcf\\macro\\figureroom\\frontend"
    }
  ]
}
